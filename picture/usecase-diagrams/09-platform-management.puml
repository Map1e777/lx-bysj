@startuml
left to right direction
skinparam packageStyle rectangle
skinparam linetype ortho

actor "系统管理员" as SysAdmin

rectangle "文档在线协作与版本管理系统" {
  usecase "管理平台用户" as UC_UserManage
  usecase "管理组织信息" as UC_OrgManage
  usecase "管理权限模板" as UC_PermTemplate
  usecase "配置版本规则" as UC_VersionRule
  usecase "查看系统审计日志" as UC_SystemAudit
  usecase "管理系统配置" as UC_Config
  usecase "查看平台统计" as UC_PlatformStat
}

SysAdmin --> UC_UserManage
SysAdmin --> UC_OrgManage
SysAdmin --> UC_PermTemplate
SysAdmin --> UC_VersionRule
SysAdmin --> UC_SystemAudit
SysAdmin --> UC_Config
SysAdmin --> UC_PlatformStat
@enduml
