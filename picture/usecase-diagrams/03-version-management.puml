@startuml
left to right direction
skinparam packageStyle rectangle
skinparam linetype ortho

actor "用户" as User

rectangle "文档在线协作与版本管理系统" {
  usecase "保存版本" as UC_SaveVersion
  usecase "查看版本历史" as UC_History
  usecase "比较版本差异" as UC_Compare
  usecase "恢复历史版本" as UC_Restore
}

User --> UC_SaveVersion
User --> UC_History
User --> UC_Compare
User --> UC_Restore
@enduml
